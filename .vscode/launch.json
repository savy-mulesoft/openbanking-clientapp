{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "mule-xml-debugger",
      "request": "launch",
      "name": "Run Mule Application",
      "noDebug": true,
      "mule.project": "${workspaceFolder}",
      "mule.runtime.args": "${config:mule.runtime.defaultArguments}"
    },
    {
      "type": "mule-xml-debugger",
      "request": "attach",
      "name": "Attach to Debug Session",
      "mule.project": "${workspaceFolder}",
      "host": "localhost",
      "port": 6668,
      "timeout": 30000
    }
  ]
}