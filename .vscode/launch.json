{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "mule-xml-debugger",
      "request": "launch",
      "name": "Run Mule Application",
      "noDebug": true,
      "mule.project": "${workspaceFolder}",
      "mule.runtime.args": "${config:mule.runtime.defaultArguments}"
    },
    {
      "name": "Maven: Clean & Package",
      "type": "shell",
      "command": "mvn",
      "args": [
        "clean",
        "package"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "type": "mule-xml-debugger",
      "request": "launch",
      "name": "Run Mule Application",
      "mule.project": "${workspaceFolder}",
      "mule.runtime.args": "${config:mule.runtime.defaultArguments}"
    },
    {
      "type": "mule-xml-debugger",
      "request": "launch",
      "name": "Debug Mule Application",
      "mule.project": "${workspaceFolder}",
      "mule.runtime.args": "${config:mule.runtime.defaultArguments}"
    }
  ]
}
