        <mxCell id="bmo-label" value="&lt;b&gt;BMO Client App&lt;/b&gt;&lt;br&gt;Mule 4.10.5 | ob_client_bmo&lt;br&gt;Port 8081 (local) / CloudHub" style="text;html=1;align=center;verticalAlign=top;fontSize=12;fillColor=none;strokeColor=none;" vertex="1" parent="1">
