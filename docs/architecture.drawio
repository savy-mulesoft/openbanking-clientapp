          <mxGeometry x="1300" y="550" width="190" height="30" as="geometry"/>
        </mxCell>

        <!-- Sequence flow note -->
        <mxCell id="seq-note" value="&lt;b&gt;FDX-Aligned Architecture&lt;/b&gt;&lt;br&gt;Both BMO and TD expose FDX Core API v6 schema: accountCategory, accountId,&lt;br&gt;nickname, currentBalance, transactionId, postedTimestamp, debitCreditMemo, payee.&lt;br&gt;&lt;br&gt;&lt;b&gt;OAuth Consent Flow Sequence&lt;/b&gt;&lt;br&gt;1. Browser → BMO /api/auth/connect?bank=TD&amp;access_types=ACCOUNT_BASIC,TRANSACTIONS&lt;br&gt;2. BMO stores pending consent in OS → 302 redirect to Auth0 /authorize&lt;br&gt;3. User consents on Auth0 → 302 redirect to BMO /callback?code=...&amp;state=...&lt;br&gt;4. BMO exchanges code for JWT at Auth0 /oauth/token&lt;br&gt;5. BMO merges pending consent + JWT → stores session in OS → 302 to UI&lt;br&gt;6. UI calls /api/oauth/session → saves to localStorage&lt;br&gt;7. UI calls /api/td/accounts → BMO loads JWT from OS → forwards to TD with Bearer" style="shape=mxgraph.basic.rect;fillColor=#f5f5f5;strokeColor=#999999;rounded=1;arcSize=8;whiteSpace=wrap;html=1;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="560" width="580" height="160" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
