        <!-- ═══════════════════════════════════════ -->
        <mxCell id="browser" value="&lt;b&gt;Browser (SPA)&lt;/b&gt;&lt;br&gt;bmo-ui.html / bmo-ui.js&lt;br&gt;&lt;br&gt;• Renders BMO dashboard&lt;br&gt;• Stores connection in localStorage&lt;br&gt;• Decodes JWT aud for bank identity&lt;br&gt;• Calls BMO API endpoints" style="shape=mxgraph.basic.rect;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;arcSize=10;whiteSpace=wrap;html=1;fontSize=11;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
