        <mxCell id="legend1" value="&lt;font color=&quot;#6c8ebf&quot;&gt;■&lt;/font&gt; Browser / Client" style="text;html=1;fillColor=none;strokeColor=none;fontSize=10;" vertex="1" parent="1">
